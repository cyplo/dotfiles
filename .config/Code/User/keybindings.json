// Place your key bindings in this file to overwrite the defaults
[
    {
        "key": "ctrl+shift+r",
        "command": "workbench.action.tasks.test",
    },
    {
        "key": "shift+alt+left",
        "command": "workbench.action.navigateBack"
    },
    {
        "key": "ctrl+alt+-",
        "command": "-workbench.action.navigateBack"
    },
    {
        "key": "shift+alt+left",
        "command": "-editor.action.smartSelect.shrink",
        "when": "editorTextFocus"
    }
]